#!/bin/bash
STATS_DIR="/var/www/html/sysstats"
TIMESTAMP=$(date +"%Y%m%d%H%M")

# CPU usage
CPU=$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5); printf "%.1f", usage}')
echo $CPU > $STATS_DIR/cpu/cpu_$TIMESTAMP.txt

# Memory usage
MEM_USED=$(free -m | awk '/Mem:/ {print $3}')
MEM_FREE=$(free -m | awk '/Mem:/ {print $4}')
echo "$MEM_USED $MEM_FREE" > $STATS_DIR/memory/memory_$TIMESTAMP.txt

# Disk usage
DISK_USED=$(df -m / | awk 'NR==2 {print $3}')
DISK_FREE=$(df -m / | awk 'NR==2 {print $4}')
echo "$DISK_USED $DISK_FREE" > $STATS_DIR/disk/disk_$TIMESTAMP.txt

# --- Optional: regenerate HTML files ---
/root/calculate_avg.sh
